        { nom: "Holstein-Stadion", ville: "Kiel", pays: "Allemagne", championnat: "2. Bundesliga", lat: 54.3391, lng: 10.1355},
        { nom: "Sportpark Ronhof", ville: "Fürth", pays: "Allemagne", championnat: "2. Bundesliga", lat: 49.4875, lng: 10.9994},
        { nom: "Signal Iduna Park", ville: "Dortmund", pays: "Allemagne", championnat: "Bundesliga", lat: 51.4926, lng: 7.4519},
        { nom: "Allianz Arena", ville: "Munich", pays: "Allemagne", championnat: "Bundesliga", lat: 48.2188, lng: 11.6247}
