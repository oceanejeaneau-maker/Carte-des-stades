      // --- PERSISTANCE localStorage ---
      const STORAGE_KEY = "stades_europe_v1";

      function sauvegarder() {
        const data = stades.map(s => ({ visite: s.visite, annee: s.annee || null }));
        localStorage.setItem(STORAGE_KEY, JSON.stringify(data));
      }

      function charger() {
        try {
          const raw = localStorage.getItem(STORAGE_KEY);
          if (!raw) return;
          const data = JSON.parse(raw);
          data.forEach((d, i) => {
            if (stades[i]) {
              stades[i].visite = !!d.visite;
              stades[i].annee = d.annee || null;
            }
          });
        } catch(e) {
          console.warn("Erreur chargement localStorage", e);
        }
      }

      // Initialiser les stades avec valeurs par défaut
      const stades = stadesDefaut.map(s => ({ ...s, visite: false, annee: null }));
      // Charger l'état sauvegardé par-dessus
      charger();

      // --- 2. INITIALISATION CARTE ---
      const map = L.map("map").setView([48.0, 8.0], 5);
      L.tileLayer("https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png", {
        attribution: '© OpenStreetMap contributors'
      }).addTo(map);

      let markers = [];

      // --- 3. ÉTAT DES FILTRES ---
      let filterState = {
        search: "",
        pays: "",
        championnat: "",
        visitedOnly: false
      };

      // --- 4. UTILITAIRES ---
      function removeAccents(str) {
        return str ? str.normalize("NFD").replace(/[\u0300-\u036f]/g, "") : "";
      }

      function isFilterActive() {
        return filterState.search || filterState.pays || filterState.championnat || filterState.visitedOnly;
      }

      function getFilteredIds() {
        return stades
          .map((s, i) => ({ ...s, id: i }))
          .filter(s => {
            if (filterState.visitedOnly && !s.visite) return false;
            if (filterState.pays && s.pays !== filterState.pays) return false;
            if (filterState.championnat && s.championnat !== filterState.championnat) return false;
            if (filterState.search) {
              const searchStr = `${s.nom} ${s.ville} ${s.pays}`.toLowerCase();
              if (!removeAccents(searchStr).includes(removeAccents(filterState.search))) return false;
            }
            return true;
          })
          .map(s => s.id);
      }

      // --- 5. STATISTIQUES ---
      function updateStats() {
        const total = stades.length;
        const visites = stades.filter(s => s.visite).length;
        const pct = total > 0 ? Math.round(visites / total * 100) : 0;
        document.getElementById("statVisites").textContent = visites;
        document.getElementById("statTotal").textContent = total;
        document.getElementById("statPct").textContent = pct + "%";
      }

      // --- 6. FILTRES ---
      function initFilters() {
        const paysSet = new Set(stades.map(s => s.pays).sort());
        const champSet = new Set(stades.map(s => s.championnat).sort());

        const paysSelect = document.getElementById("paysFilter");
        const champSelect = document.getElementById("champFilter");

        paysSet.forEach(p => {
          const opt = document.createElement("option");
          opt.value = p; opt.textContent = (drapeaux[p] || "🏳") + " " + p;
          paysSelect.appendChild(opt);
        });

        champSet.forEach(c => {
          const opt = document.createElement("option");
          opt.value = c; opt.textContent = c;
          champSelect.appendChild(opt);
        });

        document.getElementById("searchInput").addEventListener("input", (e) => {
          filterState.search = e.target.value.toLowerCase();
          renderAll();
        });

        paysSelect.addEventListener("change", (e) => {
          filterState.pays = e.target.value;
          renderAll();
        });

        champSelect.addEventListener("change", (e) => {
          filterState.championnat = e.target.value;
          renderAll();
        });

        const btnVisited = document.getElementById("btnVisited");
        btnVisited.addEventListener("click", () => {
          filterState.visitedOnly = !filterState.visitedOnly;
          btnVisited.textContent = filterState.visitedOnly ? "Afficher: Visités" : "Afficher: Tous";
          btnVisited.style.backgroundColor = filterState.visitedOnly ? "#28a745" : "#007bff";
          renderAll();
        });

        document.getElementById("btnReset").addEventListener("click", () => {
          filterState = { search: "", pays: "", championnat: "", visitedOnly: false };
          document.getElementById("searchInput").value = "";
          paysSelect.value = "";
          champSelect.value = "";
          document.getElementById("btnVisited").textContent = "Afficher: Tous";
          document.getElementById("btnVisited").style.backgroundColor = "#007bff";
          renderAll();
        });

        // FIX selectAll : coche/décoche correctement les stades filtrés
        document.getElementById("selectAll").addEventListener("change", (e) => {
          const checked = e.target.checked;
          const filteredIds = getFilteredIds();
          filteredIds.forEach(id => {
            stades[id].visite = checked;
            if (checked && !stades[id].annee) stades[id].annee = new Date().getFullYear();
            updateMarkerVisibility(id);
          });
          sauvegarder();
          updateStats();
          renderTableBody();
        });
      }

      // --- 7. CARTE ---
      function initMarkers() {
        stades.forEach((s, i) => {
          const marker = L.marker([s.lat, s.lng])
            .bindPopup(`<b>${s.nom}</b><br>${s.ville} (${s.pays})<br><i>${s.championnat}</i>`);
          markers.push({ id: i, marker });
          // Ne pas ajouter à la carte maintenant, updateMarkerVisibility s'en charge
        });
        // Appliquer la visibilité initiale
        stades.forEach((_, i) => updateMarkerVisibility(i));
      }

      function updateMarkerVisibility(id) {
        const item = markers.find(m => m.id === id);
        if (!item) return;
        if (stades[id].visite) {
          if (!map.hasLayer(item.marker)) item.marker.addTo(map);
        } else {
          if (map.hasLayer(item.marker)) map.removeLayer(item.marker);
        }
      }

      // --- 8. RENDU GLOBAL ---
      function renderAll() {
        renderTableBody();

        // Synchroniser la carte avec filtres + état visité
        const allowedIds = getFilteredIds();
        markers.forEach(m => {
          if (stades[m.id].visite && allowedIds.includes(m.id)) {
            if (!map.hasLayer(m.marker)) m.marker.addTo(map);
          } else {
            if (map.hasLayer(m.marker)) map.removeLayer(m.marker);
          }
        });
      }

      // --- 9. RENDU TABLEAU ---
      function renderTableBody() {
        const tbody = document.querySelector("#stadesTable tbody");
        tbody.innerHTML = "";

        const filteredIds = getFilteredIds();
        if (filteredIds.length === 0) {
          tbody.innerHTML = "<tr><td colspan='7' style='text-align:center'>Aucun stade ne correspond aux filtres.</td></tr>";
          return;
        }

        // Groupement Pays -> Championnat
        const grouped = {};
        filteredIds.forEach(id => {
          const s = stades[id];
          if (!grouped[s.pays]) grouped[s.pays] = {};
          if (!grouped[s.pays][s.championnat]) grouped[s.pays][s.championnat] = [];
          grouped[s.pays][s.championnat].push(id);
        });

        // FIX : déplier automatiquement si un filtre est actif
        const autoExpand = isFilterActive();

        Object.keys(grouped).sort().forEach(pays => {
          const flag = drapeaux[pays] || "🏳";
          const trCountry = document.createElement("tr");
          trCountry.className = "group-header";
          let expanded = autoExpand;
          trCountry.innerHTML = `<td colspan='7'>${flag} ${pays} <span style='float:right; font-size:0.8em'>${expanded ? "▼" : "▶"}</span></td>`;

          trCountry.addEventListener("click", () => {
            expanded = !expanded;
            const arrow = trCountry.querySelector("span");
            arrow.textContent = expanded ? "▼" : "▶";
            let next = trCountry.nextElementSibling;
            while (next && !next.classList.contains("group-header")) {
              if (expanded) {
                next.classList.remove("hidden");
              } else {
                next.classList.add("hidden");
              }
              next = next.nextElementSibling;
            }
          });

          tbody.appendChild(trCountry);

          Object.keys(grouped[pays]).sort().forEach(champ => {
            const trChamp = document.createElement("tr");
            trChamp.className = "sub-header" + (autoExpand ? "" : " hidden");
            trChamp.innerHTML = `<td colspan='7' style='padding-left:40px'>⚽ ${champ}</td>`;
            tbody.appendChild(trChamp);

            grouped[pays][champ].forEach(id => {
              const s = stades[id];
              const tr = document.createElement("tr");
              tr.className = "data-row" + (autoExpand ? "" : " hidden");

              tr.innerHTML = `
                <td><input type="checkbox" class="cb-visite" data-id="${id}" ${s.visite ? 'checked' : ''}></td>
                <td><strong>${s.nom}</strong></td>
                <td>${s.ville}</td>
                <td>${flag} ${s.pays}</td>
                <td>${s.championnat}</td>
                <td>
                  <input type="number" class="input-annee" data-id="${id}"
                    value="${s.annee || ''}"
                    min="1900" max="${new Date().getFullYear()}"
                    style="width:65px" placeholder="…">
                </td>
                <td>${s.visite ? '✅' : '❌'}</td>
              `;

              // FIX clic ligne : on cible correctement la ligne sans conflit avec les inputs
              tr.addEventListener("click", (e) => {
                if (e.target.closest("input")) return; // ignorer les clics sur inputs
                map.flyTo([s.lat, s.lng], 13);
                const markerObj = markers.find(m => m.id === id);
                if (markerObj) {
                  if (!map.hasLayer(markerObj.marker)) markerObj.marker.addTo(map);
                  markerObj.marker.openPopup();
                }
              });

              // Checkbox visité
              tr.querySelector(".cb-visite").addEventListener("change", (e) => {
                stades[id].visite = e.target.checked;
                if (e.target.checked && !stades[id].annee) {
                  stades[id].annee = new Date().getFullYear();
                }
                updateMarkerVisibility(id);
                sauvegarder();
                updateStats();
                renderTableBody();
              });

              // Input année avec validation
              tr.querySelector(".input-annee").addEventListener("change", (e) => {
                const val = parseInt(e.target.value);
                const currentYear = new Date().getFullYear();
                if (!isNaN(val) && val >= 1900 && val <= currentYear) {
                  stades[id].annee = val;
                  e.target.style.borderColor = "";
                } else if (e.target.value === "") {
                  stades[id].annee = null;
                  e.target.style.borderColor = "";
                } else {
                  e.target.style.borderColor = "red";
                  e.target.title = `Année invalide (1900-${currentYear})`;
                  return; // Ne pas sauvegarder si invalide
                }
                sauvegarder();
              });

              tbody.appendChild(tr);
            });
          });
        });
      }

      // --- 10. LANCEMENT ---
      initFilters();
      initMarkers();
      updateStats();
      renderAll();
    });
  </script>
</body>
</html>